; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Stardew Valley"
run/main_scene="uid://bljug18w0tkmg"
config/features=PackedStringArray("4.5", "GL Compatibility")
config/icon="res://addons/icon.svg"

[display]

window/size/viewport_width=768
window/size/viewport_height=816
window/size/window_width_override=768
window/size/window_height_override=816

[editor_plugins]

enabled=PackedStringArray("res://addons/godot_super-wakatime/plugin.cfg")

[layer_names]

2d_physics/layer_1="wall"
2d_physics/layer_2="player"
2d_physics/layer_3="enemies"
2d_physics/layer_4="bullets"
2d_physics/layer_5="items"

[rendering]

